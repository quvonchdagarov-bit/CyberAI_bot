# ═══════════════════════════════════════════════════════════════
# CyberAI Pro v2.1 — Konfiguratsiya shabloni
# ═══════════════════════════════════════════════════════════════
# Bu faylni .env nomi bilan nusxa oling va to'ldiring

# ── Telegram (MAJBURIY) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Admin IDlar (vergul bilan) ───────────────────────────────────────────────
ADMIN_IDS=5885964084

# ── Bot ma'lumotlari ─────────────────────────────────────────────────────────
BOT_VERSION=2.1.0
ENVIRONMENT=production

# ── Asosiy API kalitlar ──────────────────────────────────────────────────────
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# Google Safe Browsing: https://console.cloud.google.com
GOOGLE_SAFE_BROWSING_API_KEY=

# Gemini AI: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Yangi API kalitlar (ixtiyoriy, lekin tavsiya qilinadi) ───────────────────

# AbuseIPDB (bepul: 1000 so'rov/kun): https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# URLScan.io (bepul: 100 skan/kun): https://urlscan.io/user/apikey
URLSCAN_API_KEY=

# Sentry (bepul monitoring): https://sentry.io
SENTRY_DSN=

# ── Bot xulqi ────────────────────────────────────────────────────────────────
DELETE_BAD_MESSAGES=false
MAX_FILE_SIZE_MB=50
URL_ANALYSIS_LIMIT=5
GLOBAL_RISK_THRESHOLD=65

# ── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_RATE=1.5
MAX_FILES_PER_MINUTE=5
MAX_MESSAGES_PER_10S=8

# ── Papkalar ─────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
QUARANTINE_DIR=quarantine
YARA_RULES_PATH=rules/basic_rules.yar
DB_PATH=data/camcyber.db

# ── Xavfsizlik ───────────────────────────────────────────────────────────────
# Fayllarni DoD 5220.22-M standartida xavfsiz o'chirish
SECURE_DELETE=true
# Karantinda saqlash muddati (kun)
QUARANTINE_DAYS=7

# ── ClamAV ───────────────────────────────────────────────────────────────────
# Mahalliy: 127.0.0.1 | Docker: clamav
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ── Tesseract OCR ────────────────────────────────────────────────────────────
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Docker: bo'sh qoldiring
TESSERACT_CMD=

# ── AI Model ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
